generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Marketplace {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  domain    String
  createdAt DateTime @default(now())

  products Product[]
  reviews  Review[]
}

model Product {
  id               String    @id @default(cuid())
  asin             String
  title            String
  imageUrl         String?
  amazonRating     Float     @default(0)
  totalReviewCount Int       @default(0)
  latestReviewDate DateTime?
  marketplaceId    String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id])
  reviews     Review[]

  @@unique([asin, marketplaceId])
  @@index([asin])
  @@index([amazonRating])
  @@index([latestReviewDate])
}

model Review {
  id               String    @id @default(cuid())
  productId        String
  reviewExternalId String
  rating           Int
  title            String?
  body             String?   @db.Text
  reviewerName     String?
  reviewDate       DateTime
  verifiedPurchase Boolean   @default(false)
  marketplaceId    String?
  sentiment        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplace Marketplace? @relation(fields: [marketplaceId], references: [id])

  @@unique([productId, reviewExternalId])
  @@index([productId])
  @@index([reviewDate])
  @@index([rating])
  @@index([sentiment])
}

model SyncLog {
  id            String   @id @default(cuid())
  status        String
  message       String?  @db.Text
  reviewsAdded  Int      @default(0)
  productsAdded Int      @default(0)
  startedAt     DateTime @default(now())
  finishedAt    DateTime?

  @@index([startedAt])
}
